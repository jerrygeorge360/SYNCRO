# ============================================================
# SYNCRO — Backend Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ----------------------------------------------------------
# Server (required)
# ----------------------------------------------------------
PORT=3001

# ----------------------------------------------------------
# Supabase (required)
# Found at: https://supabase.com/dashboard → Project → API
# ----------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----------------------------------------------------------
# JWT (required)
# A long random secret used to sign authentication tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ----------------------------------------------------------
JWT_SECRET=your-very-long-random-jwt-secret

# ----------------------------------------------------------
# Email / SMTP (required)
# Used for transactional emails, reminders, and notifications.
# ----------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=your-smtp-password
# Optional: override the "From" display name
# SMTP_FROM_NAME=SYNCRO

# ----------------------------------------------------------
# Stripe (required)
# Found at: https://dashboard.stripe.com/apikeys
# ----------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------
# Stellar / Soroban (required)
# ----------------------------------------------------------
SOROBAN_CONTRACT_ADDRESS=your_contract_address_here
STELLAR_NETWORK_URL=https://soroban-testnet.stellar.org
# For mainnet:
# STELLAR_NETWORK_URL=https://soroban-mainnet.stellar.org

# ----------------------------------------------------------
# Risk Detection Configuration (optional — defaults provided)
# ----------------------------------------------------------
# Consecutive Failures Weights
RISK_WEIGHT_CONSECUTIVE_NONE=0
RISK_WEIGHT_CONSECUTIVE_MEDIUM=5
RISK_WEIGHT_CONSECUTIVE_HIGH=10

# Balance Projection Weights
RISK_WEIGHT_BALANCE_SUFFICIENT=0
RISK_WEIGHT_BALANCE_LOW=5
RISK_WEIGHT_BALANCE_INSUFFICIENT=10

# Approval Expiration Weights
RISK_WEIGHT_APPROVAL_VALID=0
RISK_WEIGHT_APPROVAL_EXPIRED=10

# ----------------------------------------------------------
# Protocol Health Monitor thresholds (optional)
# ----------------------------------------------------------
# HEALTH_THRESHOLD_FAILED_RENEWALS_PER_HOUR=10
# HEALTH_THRESHOLD_CONTRACT_ERRORS_PER_HOUR=5
# HEALTH_THRESHOLD_AGENT_INACTIVITY_HOURS=24

# ----------------------------------------------------------
# Auto-Expiry: days of inactivity per billing cycle (optional)
# ----------------------------------------------------------
EXPIRY_DAYS_MONTHLY=60
EXPIRY_DAYS_QUARTERLY=180
EXPIRY_DAYS_YEARLY=400
# Warning tiers before expiry (comma-separated, optional, default: 7,3,1)
# EXPIRY_WARNING_DAYS=7,3,1

# ----------------------------------------------------------
# Web Push Notifications (optional)
# Generate with: npx web-push generate-vapid-keys
# ----------------------------------------------------------
# VAPID_PUBLIC_KEY=your-vapid-public-key
# VAPID_PRIVATE_KEY=your-vapid-private-key
# VAPID_SUBJECT=mailto:admin@example.com
